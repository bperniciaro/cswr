<%@ Page Language="C#" AutoEventWireup="true" CodeFile="TestGraph.aspx.cs" Inherits="test_TestGraph" %>
<%@ Register Assembly="System.Web.DataVisualization, Version=3.5.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
  Namespace="System.Web.UI.DataVisualization.Charting" TagPrefix="asp" %>

<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">

<html xmlns="http://www.w3.org/1999/xhtml">
<head runat="server">
  <title>Chart Practice</title>
</head>
<body>
  <style type="text/css">
    body {background:White;}
  </style>
<form id="form1" runat="server">

<asp:HyperLink runat="server" NavigateUrl="http://news.google.com/news/search?aq=f&um=1&cf=all&ned=us&hl=en&q=drew+brees" Target="_blank" Text="Test" />

<%--User Registration Chart--%>
<asp:Chart ID="chtCarsPerUser" runat="server" Palette="BrightPastel" BackColor="#D3DFF0" ImageType="Png" ImageLocation="~/TempImages/ChartPic_#SEQ(300,3)" Width="412px" Height="296px" BorderDashStyle="Solid" BackGradientStyle="TopBottom" BorderWidth="2" BorderColor="26, 59, 105">   
  <Titles>
    <asp:Title ShadowColor="32, 0, 0, 0" Font="Trebuchet MS, 14.25pt, style=Bold" ShadowOffset="3" Text="User Per Car Count" ForeColor="26, 59, 105"></asp:Title>
	</Titles>
	<borderskin SkinStyle="Emboss"></borderskin>
  <legends>
	  <asp:legend LegendStyle="Row" IsTextAutoFit="true" DockedToChartArea="MainChartArea" Docking="Bottom" IsDockedInsideChartArea="False" Name="Default" BackColor="Transparent" Font="Trebuchet MS, 8.25pt, style=Bold" Alignment="Center"></asp:legend>
	</legends>
  <Series> 
    <asp:Series Name="Cars" ChartArea="MainChartArea" BorderColor="180, 26, 59, 105" Color="220, 65, 140, 240"></asp:Series> 
  </Series> 
  <ChartAreas> 
    <asp:ChartArea Name="MainChartArea">
		  <axisy LineColor="64, 64, 64, 64">
			  <LabelStyle Font="Trebuchet MS, 8.25pt, style=Bold" />
				<MajorGrid LineColor="64, 64, 64, 64" />
			</axisy>
			<axisx LineColor="64, 64, 64, 64">
			  <LabelStyle Font="Trebuchet MS, 8.25pt, style=Bold" />
				<MajorGrid LineColor="64, 64, 64, 64" />
			</axisx>
    </asp:ChartArea> 
  </ChartAreas> 
</asp:Chart> 

<br />


<%--User Registration Chart--%>
<asp:Chart ID="chtUserRegistrationChart" runat="server" Palette="BrightPastel" BackColor="#D3DFF0" ImageType="Png" ImageLocation="~/TempImages/ChartPic_#SEQ(300,3)" Width="412px" Height="296px" BorderDashStyle="Solid" BackGradientStyle="TopBottom" BorderWidth="2" BorderColor="26, 59, 105">   
  <Titles>
    <asp:Title ShadowColor="32, 0, 0, 0" Font="Trebuchet MS, 14.25pt, style=Bold" ShadowOffset="3" Text="Registered Users By Month & Year" ForeColor="26, 59, 105"></asp:Title>
	</Titles>
	<borderskin SkinStyle="Emboss"></borderskin>
  <legends>
	  <asp:legend LegendStyle="Row" IsTextAutoFit="true" DockedToChartArea="MainChartArea" Docking="Bottom" IsDockedInsideChartArea="False" Name="Default" BackColor="Transparent" Font="Trebuchet MS, 8.25pt, style=Bold" Alignment="Center"></asp:legend>
	</legends>
  <Series> 
    <asp:Series Name="2009" ChartArea="MainChartArea" BorderColor="180, 26, 59, 105" Color="220, 65, 140, 240"></asp:Series> 
    <asp:Series Name="2010" ChartArea="MainChartArea" BorderColor="180, 26, 59, 105" Color="220, 252, 180, 65"></asp:Series> 
  </Series> 
  <ChartAreas> 
    <asp:ChartArea Name="MainChartArea">
		  <axisy LineColor="64, 64, 64, 64">
			  <LabelStyle Font="Trebuchet MS, 8.25pt, style=Bold" />
				<MajorGrid LineColor="64, 64, 64, 64" />
			</axisy>
			<axisx LineColor="64, 64, 64, 64">
			  <LabelStyle Font="Trebuchet MS, 8.25pt, style=Bold" />
				<MajorGrid LineColor="64, 64, 64, 64" />
			</axisx>
    </asp:ChartArea> 
  </ChartAreas> 
</asp:Chart> 


</form>
</body>
</html>
