/* Primary Navigation */
#primaryNav {background-color:Orange;}
#primaryNav {height:69px;background:url(http://www.cheatsheetwarroom.com/styles/cssimages/layout/primarynavbackgrounds.gif) repeat-x 0 0;line-height:69px;font-family:Helvetica, Arial, sans-serif;border-right:1px solid black;border-left:1px solid black;dislay:block}

/* Primary Links */
#primaryNav ul {margin:0px;padding:0px;font-size:20px;}
#primaryNav ul li {display:inline;width:124px;height:68px;float:left;border-right:1px solid #6ec37c;}
#primaryNav ul li.sheets {width:164px;}

#primaryNav ul li a {display:block;color:white;text-decoration:none;width:123px;height:68px;text-align:center;font-weight:bold;}
#primaryNav ul li a:hover {display:block;color:white;text-decoration:none;width:123px;height:68px;background:url(http://www.cheatsheetwarroom.com/styles/cssimages/layout/primarynavbackgrounds.gif) repeat-x 0 -68px;color:white;}
#primaryNav ul li a.sheets {width:165px;}
#primaryNav ul li a.sheets:hover {background-image:url(http://www.cheatsheetwarroom.com/styles/cssimages/layout/navsheetshover2.gif);background-repeat:no-repeat;color:white;}


#primaryNav .social {margin-right:20px;padding-top:8px;vertical-align:top;height:42px;float:right;}
#primaryNav .social .userMessage {float:left;text-align:right;font-weight:bold;font-size:13px;}

#primaryNav .social .fbContainer {padding-top:8px;height:42px;float:left;margin-right:25px;}
#primaryNav .social .fbContainer a.facebookButton {display:block;width:100px;height:37px;background:url(http://www.cheatsheetwarroom.com/styles/cssimages/layout/socialsprites.gif) no-repeat 0 0;float:left;}

#primaryNav .social .twContainer {padding-top:8px;height:42px;float:left;margin-right:27px;}
#primaryNav .social .twContainer a.twitterButton {display:block;width:100px;height:37px;background:url(http://www.cheatsheetwarroom.com/styles/cssimages/layout/socialsprites.gif) no-repeat 0 -37px;float:left;}


/* AUTHENTICATED */
#primaryNav .social .userMessage .auth p.hello {color:white;margin:-17px 0px 0px 0px;padding:0px;height:30px;}
#primaryNav .social .userMessage .auth p.username {margin:-13px 0px 0px 0px;padding:0px;height:30px;}
#primaryNav .social .userMessage .auth p.username a {color:white;text-decoration:underline;}
#primaryNav .social .userMessage .auth p.username a:hover {text-decoration:none;}
/* UNAUTHENTICATED */
#primaryNav .social .userMessage .unAuth p.login {margin:0px;padding:2px 0px 0px 0px;}
#primaryNav .social .userMessage .unAuth p.login a {line-height:30px;width:103px;height:31px;display:block;background-image:url(http://www.cheatsheetwarroom.com/styles/cssimages/layout/loginbuttonbackground.gif);                                                                                   color:White;text-align:center;text-decoration:none;}
#primaryNav .social .userMessage .unAuth p.login a:hover {text-decoration:underline;}
#primaryNav .social .userMessage .unAuth p.register {margin:-24px 0px 0px 0px;padding:0px;}
#primaryNav .social .userMessage .unAuth p.register a {color:White;font-size:12px;text-decoration:none;}
#primaryNav .social .userMessage .unAuth p.register a:hover {text-decoration:underline;}


/* DYNAMIC DROPDOWN */
.mySheetsDD  {position:absolute;visibility:hidden;margin-top:-70px;width:164px;height:77px;padding-top:68px;background-image:url(http://www.cheatsheetwarroom.com/styles/cssimages/layout/primarynavdropdownbackground2.gif);}
.mySheetsDD p {text-align:center;margin:0px;}
.mySheetsDD p.football {padding:12px;}
.mySheetsDD p.racing {padding:8px;}
.mySheetsDD a {font-size:14px;font-family:Helvetica, Arial, sans-serif;color:white;font-weight:bold;text-decoration:none;}
.mySheetsDD a:hover {text-decoration:underline;}


blockquote {
  background: #f9f9f9;
  border-left: 10px solid #ccc;
  margin: 2em 10px;
  padding: 0.5em 10px;
  quotes: "\201C""\201D""\2018""\2019";
}
blockquote:before {
  color: #ccc;
  content: open-quote;
  font-size: 4em;
  line-height: 0.1em;
  margin-right: 0.25em;
  vertical-align: -0.4em;
}
blockquote p {
  display: inline;
}


table.jets th {font-size:.9em;padding:3px;background-color:#083118;color:white;text-align:center;}
table.jets tr {background-color:#eaf5ee;}
table.jets tr.alternatingColor {background-color:#dbece1;}
table.jets td {padding:2px;text-align:left;}

table.lions th {font-size:.9em;padding:3px;background-color:#1560a0;color:white;text-align:center;}
table.lions tr {background-color:#f5f1e9;}
table.lions tr.alternatingColor {background-color:#ede7d8;}
table.lions td {padding:2px;text-align:left;}

table.seahawks th {font-size:.9em;padding:3px;background-color:#00133e;color:white;text-align:center;}
table.seahawks tr {background-color:#f4efe4;}
table.seahawks tr.alternatingColor {background-color:#ede5d4;}
table.seahawks td {padding:2px;text-align:left;}
