  <!-- This should make tooltips appear in UpdatePanels, even after a callback, 
       but it does not address AJAX triggered on QTip hovers, which still don't work -->
  <script type="text/javascript">
    function pageLoad(sender, args) {
      if (args.get_isPartialLoad()) {
        $('[title]').qtip({
          overwrite: false,
          show: {
            delay: 550
          }
        });
      }
    }
  </script>



